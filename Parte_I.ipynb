## Punto 1. Análisis de los datos

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

url = "PEGA_AQUI_LA_URL_RAW_DE_GITHUB"

df = pd.read_csv(url, sep=";")
df.columns = df.columns.str.strip()

print("Cantidad de observaciones:", df.shape[0])
print("Cantidad de variables:", df.shape[1])
print("\nVariables:")
print(df.columns)
print("\nTipos de datos:")
df.info()


## Punto 2. Descripción numérica de los datos

variables=[
"Temperatura_Abrigo_150cm",
"Humedad_Media",
"Presion_Media",
"Radiacion_Global"
]

display(df[variables].describe().T)

for v in variables:
    print("="*60)
    print(v)
    print("Media:",df[v].mean())
    print("Mediana:",df[v].median())
    print("Moda:",df[v].mode()[0])
    print("Varianza:",df[v].var())
    print("Desvío estándar:",df[v].std())
    print("Mínimo:",df[v].min())
    print("Máximo:",df[v].max())
    print("Rango:",df[v].max()-df[v].min())
    print()


## Punto 3. Descripción gráfica de los datos

for v in variables:
    plt.figure(figsize=(7,4))
    plt.hist(df[v],bins=20,edgecolor="black")
    plt.title("Histograma - "+v)
    plt.xlabel(v)
    plt.ylabel("Frecuencia")
    plt.grid(True)
    plt.show()


for v in variables:
    plt.figure(figsize=(6,2))
    plt.boxplot(df[v],vert=False)
    plt.title("Boxplot - "+v)
    plt.grid(True)
    plt.show()


## Punto 4. Conclusión

Con las medidas descriptivas y los gráficos obtenidos es posible caracterizar el comportamiento de cada variable, detectar la presencia de valores extremos y conocer la dispersión de los datos. Este análisis constituye la base para los procedimientos inferenciales y de regresión desarrollados en las siguientes partes del trabajo.
